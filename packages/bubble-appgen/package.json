{
  "name": "@bubblelab/bubble-appgen",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Contract-first bubble generator: OpenAPI spec in, type-enforced ServiceBubble out (ADD-ANY-APP stages S1-S6)",
  "scripts": {
    "generate:snowflake-sql-api": "bun src/cli.ts --spec fixtures/sqlapi.yaml --config examples/snowflake-sql-api.config.json",
    "generate:stripe-payments-api": "bun src/cli.ts --spec fixtures/stripe-payments.yaml --config examples/stripe-payments-api.config.json",
    "generate:kraken-spot-api": "bun src/cli.ts --spec fixtures/kraken-spot.yaml --config examples/kraken-spot-api.config.json",
    "trim:stripe-payments-api": "bun scripts/trim-openapi.ts --trim examples/stripe-payments-api.trim.json --source",
    "trim:kraken-spot-api": "bun scripts/trim-openapi.ts --trim examples/kraken-spot-api.trim.json --source",
    "convert:bigquery": "bun scripts/discovery-to-openapi.ts",
    "generate:bigquery": "bun scripts/discovery-to-openapi.ts && bun src/cli.ts --spec fixtures/bigquery-v2.openapi.json --config examples/bigquery.config.json",
    "convert:redshift-data": "bun scripts/smithy-to-openapi.ts",
    "generate:redshift-data": "bun scripts/smithy-to-openapi.ts && bun src/cli.ts --spec fixtures/redshift-data.openapi.json --config examples/redshift-data.config.json",
    "generate:databricks-sql": "bun src/cli.ts --spec fixtures/databricks-sql-statements.yaml --config examples/databricks-sql.config.json",
    "watchdog:check": "bun scripts/watchdog-check.ts",
    "watchdog:register": "bun scripts/watchdog-register.ts",
    "watchdog:apply": "bun scripts/watchdog-apply.ts",
    "test": "bun test src/watchdog",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bubblelab/shared-schemas": "workspace:*",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@bubblelab/bubble-core": "workspace:*",
    "@types/node": "^20.12.12",
    "typescript": "^5.8.3"
  }
}
